# ─── DinnerHack Pipeline — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY   # use service role (not anon) for server-side writes

# ── Spoonacular API ───────────────────────────────────────────────────────────
# Found in: https://spoonacular.com/food-api/console → Profile → API Key
# Free tier: 150 requests/day. fetchRecipes.js uses ~70 requests per weekly run.
SPOONACULAR_API_KEY=e56f147ec621495eb8a89586a95261ca

# ── Scraper Config ────────────────────────────────────────────────────────────
ZIP_CODE=15944                 # New Florence, PA — change to your target ZIP
MIN_DISCOUNT_PCT=30            # Only include deals with ≥ this % off
MAX_RETRIES=2                  # How many times to retry on failure
RETRY_DELAY=10000              # Milliseconds between retries

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                 # debug | info | warn | error
